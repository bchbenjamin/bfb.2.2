# ============================================
# BengaluruDuru Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/bengaluruduru?sslmode=require

# Gemini AI (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_minimum_32_characters_long

# File Uploads
UPLOAD_DIR=./uploads

# Server
PORT=3001
NODE_ENV=development

# Admin Login Credentials
ADMIN_EMAIL=officer@bbmp.gov.in
ADMIN_PASSWORD=bbmp123

# Client (used by Vite)
VITE_API_URL=http://localhost:3001
