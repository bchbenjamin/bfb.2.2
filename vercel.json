{
  "buildCommand": "npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "server/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  }
}
